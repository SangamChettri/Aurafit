// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums matching Sequelize models
enum FitnessGoal {
  weight_loss
  muscle_gain
  endurance
  general_fitness
  strength
}

enum WorkoutType {
  strength
  cardio
  hiit
  yoga
  pilates
  crossfit
  sports
  other
}

enum Gender {
  male
  female
  other
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  very_active
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum Role {
  user
  admin
  super_admin
}

enum ExerciseCategory {
  Barbell
  Dumbbell
  Machine
  Bodyweight
  Cardio
  Cable
  Other
}

enum MuscleGroup {
  Chest
  Back
  Shoulders
  Biceps
  Triceps
  Legs
  Core
  FullBody
  Cardio
}

enum SetType {
  Normal
  Warmup
  DropSet
  Failure
}

enum GoalType {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  ENDURANCE
  FLEXIBILITY
}

model User {
  id                        Int               @id @default(autoincrement())
  name                      String            @db.VarChar(255)
  email                     String            @unique @db.VarChar(255)
  password                  String            @db.VarChar(255)
  avatar                    String?           @db.VarChar(500)
  fitness_goal              FitnessGoal       @default(general_fitness) @map("fitness_goal")
  height                    Decimal?          @db.Decimal(5, 2)
  weight                    Decimal?          @db.Decimal(5, 2)
  age                       Int?
  gender                    Gender?
  activity_level            ActivityLevel     @default(moderate)
  email_verified            Boolean           @default(false) @map("email_verified")
  email_verification_token  String?           @map("email_verification_token") @db.VarChar(500)
  password_reset_token      String?           @map("password_reset_token") @db.VarChar(500)
  password_reset_expires    DateTime?         @map("password_reset_expires")
  last_login                DateTime?         @map("last_login")
  is_active                 Boolean           @default(true) @map("is_active")
  is_premium                Boolean           @default(false) @map("is_premium")
  role                      Role              @default(user) @map("role")
  premium_expires           DateTime?         @map("premium_expires")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  // Relations
  workouts                  Workout[]
  progress                  Progress[]
  streaks                   Streak[]
  notifications             Notification[]
  personalRecords           PersonalRecord[]
  userSettings              UserSettings[]
  templates                 WorkoutTemplate[]
  measurements              BodyMeasurement[]
  following                 UserFollow[]       @relation("UserFollowers")
  followers                 UserFollow[]       @relation("UserFollowing")
  sessionLikes              SessionLike[]
  sessionComments           SessionComment[]
  goals                     Goal[]
  waterLogs                 WaterLog[]
  achievements              UserAchievement[]

  @@index([email])
  @@index([fitness_goal])
  @@index([createdAt])
  @@index([email_verified])
  @@index([is_active])
  @@map("users")
}

model Workout {
  id             Int               @id @default(autoincrement())
  userId         Int               @map("user_id")
  templateId     Int?              @map("template_id")
  name           String            @db.VarChar(255)
  date           DateTime          @default(now()) @map("date")
  endTime        DateTime?         @map("end_time")
  duration       Int?
  notes          String?           @db.Text
  totalVolume    Decimal?          @db.Decimal(10,2) @map("total_volume")
  totalSets      Int?              @map("total_sets")
  totalReps      Int?              @map("total_reps")
  isPublic       Boolean           @default(false) @map("is_public")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       WorkoutTemplate?  @relation(fields: [templateId], references: [id])
  exercises      Exercise[]
  likes          SessionLike[]
  comments       SessionComment[]

  @@index([userId])
  @@index([userId, date])
  @@index([isPublic])
  @@map("workouts")
}

model Exercise {
  id            Int             @id @default(autoincrement())
  workoutId     Int             @map("workout_id")
  exerciseId    Int             @map("exercise_id")
  exerciseName  String          @db.VarChar(255) @map("exercise_name")
  order         Int             @default(0)
  createdAt     DateTime        @default(now()) @map("created_at")

  workout       Workout         @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  libraryRecord ExerciseLibrary @relation(fields: [exerciseId], references: [id])
  sets          ExerciseSet[]

  @@index([workoutId])
  @@map("exercises")
}

model ExerciseSet {
  id                Int             @id @default(autoincrement())
  exerciseId        Int             @map("exercise_id")
  setNumber         Int             @map("set_number")
  type              SetType         @default(Normal)
  weight            Decimal?        @db.Decimal(6,2)
  reps              Int?
  duration          Int?
  distance          Decimal?        @db.Decimal(8,2)
  rpe               Int?
  isCompleted       Boolean         @default(false) @map("is_completed")
  restTime          Int?            @map("rest_time")
  isPR              Boolean         @default(false) @map("is_pr")
  createdAt         DateTime        @default(now()) @map("created_at")

  exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_sets")
}

model BodyMeasurement {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  date       DateTime  @db.Date
  weight     Decimal?  @db.Decimal(5,2)
  bodyFat    Decimal?  @db.Decimal(5,2) @map("body_fat")
  muscleMass Decimal?  @db.Decimal(5,2) @map("muscle_mass")
  bmi        Decimal?  @db.Decimal(4,2)
  height     Decimal?  @db.Decimal(5,2)
  chest      Decimal?  @db.Decimal(5,2)
  waist      Decimal?  @db.Decimal(5,2)
  hips       Decimal?  @db.Decimal(5,2)
  arms       Decimal?  @db.Decimal(5,2)
  thighs     Decimal?  @db.Decimal(5,2)
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("body_measurements")
}

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model SessionLike {
  id        Int      @id @default(autoincrement())
  workoutId Int      @map("workout_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId])
  @@map("session_likes")
}

model SessionComment {
  id        Int      @id @default(autoincrement())
  workoutId Int      @map("workout_id")
  userId    Int      @map("user_id")
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@map("session_comments")
}

model Goal {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  type         GoalType
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  targetValue  Decimal?  @db.Decimal(8,2) @map("target_value")
  currentValue Decimal?  @db.Decimal(8,2) @map("current_value")
  unit         String?   @db.VarChar(50)
  targetDate   DateTime? @map("target_date")
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

model WaterLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  amount    Decimal  @db.Decimal(6,2)
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("water_logs")
}

model Achievement {
  id          Int               @id @default(autoincrement())
  title       String            @db.VarChar(255)
  description String            @db.Text
  icon        String            @db.VarChar(100)
  category    String            @default("general") @db.VarChar(50)
  criteria    Json?             // Stores criteria like { type: 'workout_count', target: 10 }
  points      Int               @default(0)
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int         @id @default(autoincrement())
  userId        Int         @map("user_id")
  achievementId Int         @map("achievement_id")
  earnedAt      DateTime    @default(now()) @map("earned_at")
  isNew         Boolean     @default(true) @map("is_new") // Whether the user has seen the notification

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

model Progress {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  date         DateTime @default(now())
  weight       Decimal? @db.Decimal(5, 2)
  bodyFat      Decimal? @db.Decimal(5, 2) @map("body_fat")
  measurements Json?
  photos       Json?
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("progress")
}

model Streak {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique @map("user_id")
  currentStreak       Int      @default(0) @map("current_streak")
  longestStreak       Int      @default(0) @map("longest_streak")
  lastWorkoutDate     DateTime? @map("last_workout_date")
  freezeDaysUsed      Int      @default(0) @map("freeze_days_used")
  freezeDaysAvailable Int      @default(3) @map("freeze_days_available")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model PersonalRecord {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  exerciseName String   @db.VarChar(255) @map("exercise_name")
  weight       Decimal? @db.Decimal(8, 2)
  reps         Int?
  distance     Decimal? @db.Decimal(8, 2)
  duration     Int?
  date         DateTime @default(now())
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseName])
  @@map("personal_records")
}

model UserSettings {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique @map("user_id")
  notificationsEnabled     Boolean  @default(true) @map("notifications_enabled")
  dailyReminderTime        String?  @map("daily_reminder_time") @db.VarChar(10)
  weeklyReportDay          String   @default("monday") @map("weekly_report_day") @db.VarChar(20)
  units                    String   @default("metric") @db.VarChar(20)
  privacyLevel             String   @default("private") @map("privacy_level") @db.VarChar(20)
  achievementNotifications  Boolean  @default(true) @map("achievement_notifications")
  streakNotifications       Boolean  @default(true) @map("streak_notifications")
  progressNotifications     Boolean  @default(true) @map("progress_notifications")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model WorkoutTemplate {
  id          Int                @id @default(autoincrement())
  userId      Int                @map("user_id")
  name        String             @db.VarChar(255)
  description String?            @db.Text
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
  workouts    Workout[]

  @@index([userId])
  @@map("workout_templates")
}

model TemplateExercise {
  id           Int             @id @default(autoincrement())
  templateId   Int             @map("template_id")
  exerciseId   Int             @map("exercise_id")
  order        Int             @default(0)
  targetSets   Int?            @map("target_sets")
  targetReps   Int?            @map("target_reps")
  targetWeight Decimal?        @db.Decimal(8, 2) @map("target_weight")
  restSeconds  Int?            @map("rest_seconds")

  template     WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise     ExerciseLibrary @relation(fields: [exerciseId], references: [id])

  @@index([templateId])
  @@map("template_exercises")
}

model ExerciseLibrary {
  id           Int                @id @default(autoincrement())
  name         String             @db.VarChar(255)
  category     String?            @db.VarChar(100)
  muscleGroup  String?            @map("muscle_group") @db.VarChar(100)
  equipment    String?            @db.VarChar(100)
  instructions String?            @db.Text
  imageUrl     String?            @map("image_url") @db.VarChar(500)
  isCustom     Boolean            @default(false) @map("is_custom")
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  exercises    Exercise[]
  templateEx   TemplateExercise[]

  @@map("exercise_library")
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  adminId    Int      @map("admin_id")
  action     String   @db.VarChar(255)
  resource   String   @db.VarChar(255)
  resourceId String?  @map("resource_id") @db.VarChar(255)
  details    String?  @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}
